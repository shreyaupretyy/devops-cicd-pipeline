{
  "name": "devops-todo-app",
  "version": "1.0.0",
  "description": "Simple To-Do app with Prometheus metrics",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "test": "jest --forceExit --detectOpenHandles --rootDir=.."
